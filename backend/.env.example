# SDLC Visualizer Backend Environment Variables

# Database
DATABASE_URL=sqlite+aiosqlite:///data/sdlc-visualizer.db
DATABASE_ECHO=false

# Application
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173

# File Upload
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=uploads

# Optional OpenUI prototype service health check (disabled by default)
# OPENUI_HEALTH_CHECK_ENABLED=false
# OPENUI_URL=http://localhost:3000
